				"cmake -S \"$PACKAGE_DIR\\llama.cpp-master\" -B \"$PACKAGE_DIR\\build\\llama.cpp-build\" -DCMAKE_BUILD_TYPE=Release -DGGML_CUDA=ON -DLLAMA_BUILD_TESTS=OFF -DLLAMA_BUILD_EXAMPLES=OFF -DLLAMA_BUILD_TOOLS=OFF -DBUILD_SHARED_LIBS=OFF -DGGML_NATIVE=OFF",
				"cmake --build \"$PACKAGE_DIR\\build\\llama.cpp-build\" --config Release --target llama"
