{
	"name": "llama-cpp-d",
	"description": "D bindings for llama-cpp",
	"license": "MIT",
	"authors": [
		"Matheus Catarino França"
	],
	"version": "0.1.3",
	"targetPath": "build",
	"toolchainRequirements": {
		"frontend": ">=2.111.0"
	},
	"buildTypes": {
		"debug": {
			"buildOptions": [
				"debugMode",
				"debugInfo",
				"debugInfoC"
			]
		},
		"release": {
			"buildOptions": [
				"inline",
				"optimize"
			]
		},
		"release-debug": {
			"buildOptions": [
				"debugInfo",
				"inline",
				"optimize"
			]
		},
		"release-nobounds": {
			"buildOptions": [
				"releaseMode",
				"inline",
				"noBoundsCheck",
				"optimize"
			]
		}
	},
	"sourcePaths": [
		"source"
	],
	"importPaths": [
		"source"
	],
	"dflags": [
		"-preview=all",
		"-P-I$PACKAGE_DIR/llama.cpp-master/ggml/include",
		"-P-I$PACKAGE_DIR/llama.cpp-master/include",
		"-P-I$PACKAGE_DIR/llama.cpp-master/tools/mtmd"
	],
	"lflags-posix": [
		"-L$PACKAGE_DIR/build/llama.cpp-build/src",
		"-L$PACKAGE_DIR/build/llama.cpp-build/ggml/src",
		"-L$PACKAGE_DIR/build/llama.cpp-build/common"
	],
	"libs-windows": [
		"advapi32"
	],
	"lflags-windows": [
		"/LIBPATH:$PACKAGE_DIR\\build\\llama.cpp-build\\src\\Release",
		"/LIBPATH:$PACKAGE_DIR\\build\\llama.cpp-build\\ggml\\src\\Release",
		"/LIBPATH:$PACKAGE_DIR\\build\\llama.cpp-build\\common\\Release",
		"/NODEFAULTLIB:libcmt.lib",
		"/NODEFAULTLIB:libcmtd.lib",
		"/NODEFAULTLIB:libvcruntime.lib",
		"/DEFAULTLIB:ucrt.lib"
	],
	"libs": [
		"common-shims",
		"common",
		"llama",
		"ggml",
		"ggml-base",
		"ggml-cpu"
	],
	"libs-linux": [
		"stdc++"
	],
	"libs-osx": [
		"c++",
		"ggml-blas",
		"ggml-metal"
	],
	"lflags-osx": [
		"-L$PACKAGE_DIR/build/llama.cpp-build/ggml/src/ggml-blas",
		"-L$PACKAGE_DIR/build/llama.cpp-build/ggml/src/ggml-metal",
		"-framework",
		"Accelerate",
		"-framework",
		"Metal",
		"-framework",
		"Foundation",
		"-framework",
		"MetalKit"
	],
	"configurations": [
		{
			"name": "default",
			"preBuildCommands-posix": [
				"test -d $PACKAGE_DIR/llama.cpp-master || (curl -sL https://github.com/ggml-org/llama.cpp/archive/refs/heads/master.tar.gz -o llama_cpp.tar.gz && tar -xzf llama_cpp.tar.gz -C $PACKAGE_DIR && rm llama_cpp.tar.gz)",
				"test -d $PACKAGE_DIR/build/llama.cpp-build || cmake -S $PACKAGE_DIR/llama.cpp-master -B $PACKAGE_DIR/build/llama.cpp-build -DCMAKE_BUILD_TYPE=Release -DLLAMA_BUILD_TESTS=OFF -DLLAMA_BUILD_EXAMPLES=OFF -DLLAMA_BUILD_TOOLS=OFF -DBUILD_SHARED_LIBS=OFF -DGGML_OPENMP=OFF -DGGML_NATIVE=OFF",
				"cmake --build $PACKAGE_DIR/build/llama.cpp-build --config Release --target llama common",
				"g++ -std=c++17 -O2 -I$PACKAGE_DIR/llama.cpp-master/include -I$PACKAGE_DIR/llama.cpp-master/ggml/include -I$PACKAGE_DIR/llama.cpp-master/common -I$PACKAGE_DIR/source/c -c $PACKAGE_DIR/source/c/common_shims.cpp -o $PACKAGE_DIR/build/common_shims.o",
				"ar rcs $PACKAGE_DIR/build/llama.cpp-build/common/libcommon-shims.a $PACKAGE_DIR/build/common_shims.o",
				"rm $PACKAGE_DIR/build/*.o"
			],
			"preBuildCommands-windows": [
				"if not exist \"$PACKAGE_DIR\\llama.cpp-master\" powershell -Command \"(New-Object Net.WebClient).DownloadFile('https://github.com/ggml-org/llama.cpp/archive/refs/heads/master.zip', '$PACKAGE_DIR\\llama_cpp.zip')\"",
				"if not exist \"$PACKAGE_DIR\\llama.cpp-master\" powershell -Command \"Expand-Archive -Path '$PACKAGE_DIR\\llama_cpp.zip' -DestinationPath '$PACKAGE_DIR' -Force; Remove-Item '$PACKAGE_DIR\\llama_cpp.zip'\"",
				"if not exist \"$PACKAGE_DIR\\build\\llama.cpp-build\" cmake -S \"$PACKAGE_DIR\\llama.cpp-master\" -B \"$PACKAGE_DIR\\build\\llama.cpp-build\" -DCMAKE_BUILD_TYPE=Release -DLLAMA_BUILD_TESTS=OFF -DLLAMA_BUILD_EXAMPLES=OFF -DLLAMA_BUILD_TOOLS=OFF -DBUILD_SHARED_LIBS=OFF -DGGML_OPENMP=OFF -DGGML_NATIVE=OFF",
				"cmake --build \"$PACKAGE_DIR\\build\\llama.cpp-build\" --config Release --target llama common",
				"powershell -Command \"cl.exe /nologo /W0 /O2 /MD /DNDEBUG /D_CRT_SECURE_NO_DEPRECATE /DNO_SEH_AVAILABLE /DNO_EXECUTE_PERMISSION /I$PACKAGE_DIR\\llama.cpp-master\\include /I$PACKAGE_DIR\\llama.cpp-master\\ggml\\include /I$PACKAGE_DIR\\llama.cpp-master\\common /I$PACKAGE_DIR\\source\\c\\include /c $PACKAGE_DIR\\src\\c\\common_shims.cpp /Fo$PACKAGE_DIR\\build\\common_shims.obj\"",
				"powershell -Command \"lib.exe /nologo /OUT:$PACKAGE_DIR\\build\\llama.cpp-build\\common\\Release\\common-shims.lib $PACKAGE_DIR\\build\\common-shims.obj\"",
				"powershell -Command \"Remove-Item $PACKAGE_DIR\\build\\*.obj\""
			]
		},
