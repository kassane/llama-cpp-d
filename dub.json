{
	"name": "llama-cpp-d",
	"description": "llama-cpp bindings for D",
	"license": "MIT",
	"authors": [
		"Matheus Catarino França"
	],
	"version": "0.1.0",
	"targetPath": "build",
	"toolchainRequirements": {
		"frontend": ">=2.111.0"
	},
	"buildTypes": {
		"debug": {
			"buildOptions": [
				"debugMode",
				"debugInfo",
				"debugInfoC"
			]
		},
		"release": {
			"buildOptions": [
				"inline",
				"optimize"
			]
		},
		"release-debug": {
			"buildOptions": [
				"debugInfo",
				"inline",
				"optimize"
			]
		},
		"release-nobounds": {
			"buildOptions": [
				"releaseMode",
				"inline",
				"noBoundsCheck",
				"optimize"
			]
		}
	},
	"sourcePaths": [
		"source"
	],
	"importPaths": [
		"source"
	],
	"dflags": [
		"-preview=all",
		"-P-I$PACKAGE_DIR/llama.cpp-master/ggml/include",
		"-P-I$PACKAGE_DIR/llama.cpp-master/include"
	],
	"lflags-posix": [
		"-L$PACKAGE_DIR/build/llama.cpp-build/src",
		"-L$PACKAGE_DIR/build/llama.cpp-build/ggml/src"
	],
	"libs-windows": [
		"advapi32"
	],
	"lflags-windows": [
		"/LIBPATH:$PACKAGE_DIR\\build\\llama.cpp-build\\src\\Release",
		"/LIBPATH:$PACKAGE_DIR\\build\\llama.cpp-build\\ggml\\src\\Release",
		"/NODEFAULTLIB:libcmt.lib",
		"/NODEFAULTLIB:libcmtd.lib",
		"/NODEFAULTLIB:libvcruntime.lib",
		"/DEFAULTLIB:ucrt.lib"
	],
	"libs": [
		"llama",
		"ggml",
		"ggml-base",
		"ggml-cpu"
	],
	"libs-linux": [
		"stdc++"
	],
	"libs-osx": [
		"c++",
		"ggml-blas",
		"ggml-metal"
	],
	"lflags-osx": [
		"-L$PACKAGE_DIR/build/llama.cpp-build/ggml/src/ggml-blas",
		"-L$PACKAGE_DIR/build/llama.cpp-build/ggml/src/ggml-metal",
		"-framework",
		"Accelerate",
		"-framework",
		"Metal",
		"-framework",
		"Foundation",
		"-framework",
		"MetalKit"
	],
	"configurations": [
		{
			"name": "default",
			"preBuildCommands-posix": [
				"test -d $PACKAGE_DIR/llama.cpp-master || (curl -sL https://github.com/ggml-org/llama.cpp/archive/refs/heads/master.tar.gz -o llama_cpp.tar.gz && tar -xzf llama_cpp.tar.gz -C $PACKAGE_DIR && rm llama_cpp.tar.gz)",
				"test -d $PACKAGE_DIR/build/llama.cpp-build || cmake -S $PACKAGE_DIR/llama.cpp-master -B $PACKAGE_DIR/build/llama.cpp-build -GNinja -DCMAKE_BUILD_TYPE=Release -DLLAMA_BUILD_TESTS=OFF -DLLAMA_BUILD_EXAMPLES=OFF -DLLAMA_BUILD_TOOLS=OFF -DBUILD_SHARED_LIBS=OFF -DGGML_OPENMP=OFF -DGGML_NATIVE=OFF",
				"cmake --build $PACKAGE_DIR/build/llama.cpp-build --config Release --target llama"
			],
			"preBuildCommands-windows": [
				"if not exist \"$PACKAGE_DIR\\llama.cpp-master\" powershell -Command \"(New-Object Net.WebClient).DownloadFile('https://github.com/ggml-org/llama.cpp/archive/refs/heads/master.zip', '$PACKAGE_DIR\\llama_cpp.zip')\"",
				"if not exist \"$PACKAGE_DIR\\llama.cpp-master\" powershell -Command \"Expand-Archive -Path '$PACKAGE_DIR\\llama_cpp.zip' -DestinationPath '$PACKAGE_DIR' -Force; Remove-Item '$PACKAGE_DIR\\llama_cpp.zip'\"",
				"if not exist \"$PACKAGE_DIR\\build\\llama.cpp-build\" cmake -S \"$PACKAGE_DIR\\llama.cpp-master\" -B \"$PACKAGE_DIR\\build\\llama.cpp-build\" -DCMAKE_BUILD_TYPE=Release -DLLAMA_BUILD_TESTS=OFF -DLLAMA_BUILD_EXAMPLES=OFF -DLLAMA_BUILD_TOOLS=OFF -DBUILD_SHARED_LIBS=OFF -DGGML_OPENMP=OFF -DGGML_NATIVE=OFF",
				"cmake --build \"$PACKAGE_DIR\\build\\llama.cpp-build\" --config Release --target llama"
			]
		},
		{
			"name": "cuda",
			"libs": [
				"llama",
